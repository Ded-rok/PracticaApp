<Window x:Class="PracticaWpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Темы курсовых работ" Height="450" Width="800"
        Loaded="Window_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <Button x:Name="btnAdd" Content="Добавить" Width="80" Height="30" Margin="5" Click="btnAdd_Click"/>
            <Button x:Name="btnEdit" Content="Редактировать" Width="100" Height="30" Margin="5" Click="btnEdit_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="80" Height="30" Margin="5" Click="btnDelete_Click"/>
            <Button x:Name="btnRefresh" Content="Обновить" Width="80" Height="30" Margin="5" Click="btnRefresh_Click"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
            <TextBox x:Name="txtSearch" Width="200" Height="25" Margin="5" ToolTip="Введите название темы"/>
            <Button x:Name="btnSearch" Content="Найти" Width="80" Height="30" Click="btnSearch_Click"/>
        </StackPanel>

        <DataGrid x:Name="dgTopics" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionUnit="FullRow" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название темы" Binding="{Binding Title}" Width="200"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="200"/>
                <DataGridTextColumn Header="Преподаватель" Binding="{Binding Teacher}" Width="120"/>
                <DataGridTextColumn Header="Студент" Binding="{Binding Student}" Width="120"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy'}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>